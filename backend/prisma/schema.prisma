// Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 정비사 모델
model Mechanic {
  id          Int      @id @default(autoincrement())
  name        String   // 정비소 이름
  location    String   // 지역명 (예: 강남구, 서초구)
  phone       String   // 전화번호
  description String?  @db.Text // 설명
  address     String   // 상세 주소

  // 지도 좌표 (Decimal 타입으로 정확도 유지)
  mapLat      Decimal  @db.Decimal(10, 8) // 위도
  mapLng      Decimal  @db.Decimal(11, 8) // 경도

  // 이미지
  mainImageUrl    String?  // 대표 이미지 URL
  galleryImages   Json?    // 갤러리 이미지 배열 ["url1", "url2", ...]

  // 유튜브
  youtubeUrl      String?  // 유튜브 숏폼(쇼츠) URL
  youtubeLongUrl  String?  // 유튜브 롱폼(일반 영상) URL

  // 상세 정보
  operatingHours    Json?    // 운영시간 {"mon":{"open":"09:00","close":"18:00"}, ...}
  specialties       Json?    // 전문 분야 ["엔진","미션","판금도색"]
  isVerified        Boolean  @default(false) // YouTube 인증 배지
  parkingAvailable  Boolean? // 주차 가능 여부 (null: 미정)
  paymentMethods    Json?    // 결제 수단 ["현금","카드","카카오페이"]
  holidays          Json?    // 휴무일 {"type":"weekly","days":["sun"],"description":"일요일 휴무"}
  kakaoOpenChatUrl  String?  // 카카오 오픈채팅 링크

  // 통계
  clickCount        Int      @default(0) // 클릭 수
  phoneRevealCount  Int      @default(0) // 전화번호 공개 수

  // 정렬
  sortOrder       Int      @default(0) // 정렬 순서 (낮을수록 먼저 표시)

  // 상태
  isActive        Boolean  @default(true)  // 활성화 여부
  isPremium       Boolean  @default(false) // 프리미엄 카드 노출

  // 타임스탬프
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // 사용자 연결 (사장님이 직접 등록한 매장)
  userId          Int?
  user            User?    @relation(fields: [userId], references: [id])

  // 관계
  clickLogs        ClickLog[]
  phoneRevealLogs  PhoneRevealLog[]
  quoteRequests    QuoteRequest[]
  reviews          Review[]
  serviceInquiries ServiceInquiry[]

  // 인덱스
  @@index([location]) // 지역별 검색 최적화
  @@index([isActive])
  @@index([isPremium])
  @@index([userId])
  @@index([sortOrder])
}

// ========================================
// 👤 통합 사용자(User) 모델
// ========================================

enum BusinessStatus {
  NONE        // 일반 회원 (사업자 등록 안 함)
  PENDING     // 사업자 등록 신청 (승인 대기)
  APPROVED    // 승인됨
  REJECTED    // 거절됨
}

model User {
  id                  Int             @id @default(autoincrement())
  kakaoId             String          @unique
  email               String?
  nickname            String?
  profileImage        String?
  phone               String?

  // 사업자 관련 (사업자 신청 시에만 사용)
  businessStatus      BusinessStatus  @default(NONE)
  businessLicenseUrl  String?
  businessName        String?
  address             String?
  rejectionReason     String?
  isProtected         Boolean         @default(false)
  deactivatedAt       DateTime?
  signupInquiryId     Int?

  // 추적
  trackingCode        String?
  trackingLink        TrackingLink?   @relation(fields: [trackingCode], references: [code])

  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  // 관계
  mechanics           Mechanic[]
  serviceInquiries    ServiceInquiry[]
  posts               Post[]
  comments            Comment[]
  postLikes           PostLike[]

  @@index([kakaoId])
  @@index([businessStatus])
  @@index([phone])
  @@index([trackingCode])
}

// 관리자 모델
model Admin {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String   // bcrypt 해시
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 전화번호 공개 로그 모델
model PhoneRevealLog {
  id          Int      @id @default(autoincrement())
  mechanicId  Int
  mechanic    Mechanic @relation(fields: [mechanicId], references: [id], onDelete: Cascade)
  ipAddress   String?
  userAgent   String?  @db.Text
  isBot       Boolean  @default(false)
  revealedAt  DateTime @default(now())

  @@index([mechanicId, revealedAt])
  @@index([ipAddress])
}

// 클릭 로그 모델
model ClickLog {
  id         Int      @id @default(autoincrement())
  mechanicId Int
  mechanic   Mechanic @relation(fields: [mechanicId], references: [id], onDelete: Cascade)
  ipAddress  String?  // 클릭한 IP
  userAgent  String?  @db.Text // User-Agent 헤더
  isBot      Boolean  @default(false) // 봇 여부
  clickedAt  DateTime @default(now())

  @@index([mechanicId, clickedAt])
  @@index([ipAddress])
}

// 문의 모델
enum InquiryType {
  CUSTOMER  // 소비자(고객) 문의
  MECHANIC  // 정비사(사장님) 문의
}

model Inquiry {
  id            Int         @id @default(autoincrement())
  type          InquiryType // 문의 유형
  name          String      // 이름 또는 대표자명
  phone         String      // 연락처
  businessName  String?     // 상호명 (정비사 문의 시)
  content       String      @db.Text // 문의 내용
  reply         String?     @db.Text // 답변 내용
  isRead        Boolean     @default(false) // 읽음 여부
  repliedAt     DateTime?   // 답변 일시
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([type])
  @@index([isRead])
  @@index([createdAt])
}

// 견적 요청 상태
enum QuoteRequestStatus {
  PENDING    // 접수됨
  VIEWED     // 확인됨
  REPLIED    // 답변됨
  COMPLETED  // 완료
  CANCELLED  // 취소
}

// 견적 요청 모델
model QuoteRequest {
  id            Int                @id @default(autoincrement())
  mechanicId    Int
  mechanic      Mechanic           @relation(fields: [mechanicId], references: [id], onDelete: Cascade)

  // 고객 정보
  customerName  String             // 고객 이름
  customerPhone String             // 고객 연락처
  carModel      String             // 차종 (예: 현대 아반떼 2023)
  carYear       String?            // 연식
  description   String    @db.Text // 증상/요청 내용

  // 사진 첨부
  images        Json?              // ["url1", "url2"] - S3 URLs (최대 3장)

  status        QuoteRequestStatus @default(PENDING)

  // 알림톡 발송 여부
  alimtalkSent    Boolean   @default(false)
  alimtalkSentAt  DateTime?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([mechanicId, status])
  @@index([mechanicId, createdAt])
  @@index([status])
}

// 한줄 리뷰 모델
model Review {
  id          Int      @id @default(autoincrement())
  mechanicId  Int
  mechanic    Mechanic @relation(fields: [mechanicId], references: [id], onDelete: Cascade)

  nickname    String              // 닉네임
  content     String   @db.VarChar(100) // 한줄 리뷰 (최대 100자)
  rating      Int      @default(5) // 1-5 별점

  isApproved  Boolean  @default(false) // 관리자 승인 필요
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([mechanicId, isApproved, isActive])
  @@index([createdAt])
}

// 페이지뷰 로그 모델
model PageView {
  id         Int      @id @default(autoincrement())
  path       String   // 페이지 경로
  ipAddress  String?  // 방문자 IP
  userAgent  String?  @db.Text // User-Agent 헤더
  isBot      Boolean  @default(false) // 봇 여부
  referer    String?  // 리퍼러 URL
  viewedAt   DateTime @default(now())

  @@index([path, viewedAt])
  @@index([isBot])
}

// ========================================
// 📱💻 폰-컴퓨터 동기화 (Sync) 모델
// ========================================

enum SyncMessageType {
  INSTRUCTION  // 지시/명령
  NOTE         // 메모
  LINK         // 링크
  IMAGE        // 이미지
}

enum SyncMessageStatus {
  PENDING      // 대기
  IN_PROGRESS  // 진행 중
  COMPLETED    // 완료
  CANCELLED    // 취소
}

model SyncMessage {
  id          Int               @id @default(autoincrement())
  content     String            @db.Text         // 지시 내용
  type        SyncMessageType   @default(INSTRUCTION)
  status      SyncMessageStatus @default(PENDING)
  deviceFrom  String            @default("phone") // "phone" | "computer"
  priority    Int               @default(0)       // 0=보통, 1=높음, 2=긴급
  images      Json?             // S3 이미지 URL 배열
  reply       String?           @db.Text          // 답변/메모
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  completedAt DateTime?

  @@index([status])
  @@index([createdAt])
  @@index([deviceFrom])
}

// ========================================
// 🔗 추적 링크 (Tracking Link) 모델
// ========================================

// 추적 링크 — 단톡방/카페 등에 공유할 때 고유 코드 부여
model TrackingLink {
  id          Int      @id @default(autoincrement())
  code        String   @unique  // 고유 코드 (예: "abc123")
  name        String             // 관리용 이름 (예: "강남맘카페")
  description String?            // 설명 (선택)
  targetUrl   String   @default("/")  // 도착 페이지 (기본: 홈)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clicks      LinkClick[]
  users       User[]
  inquiries   ServiceInquiry[]

  @@index([code])
  @@index([isActive])
}

// 링크 클릭 로그
model LinkClick {
  id             Int          @id @default(autoincrement())
  trackingLinkId Int
  trackingLink   TrackingLink @relation(fields: [trackingLinkId], references: [id], onDelete: Cascade)
  ipAddress      String?
  userAgent      String?      @db.Text
  isBot          Boolean      @default(false)
  clickedAt      DateTime     @default(now())

  @@index([trackingLinkId, clickedAt])
  @@index([ipAddress])
}

// 타이어 문의 상태
enum TireInquiryStatus {
  PENDING      // 접수됨
  IN_PROGRESS  // 처리중 (관리자가 정비소 연결 중)
  MATCHED      // 정비소 매칭됨
  COMPLETED    // 완료
  CANCELLED    // 취소
}

// 타이어 문의 서비스 타입
enum TireServiceType {
  REPLACEMENT  // 타이어 교체
  REPAIR       // 펑크 수리
  ALIGNMENT    // 얼라인먼트
  INSPECTION   // 타이어 점검
}

// 서비스 문의 타입
enum ServiceType {
  TIRE         // 타이어 (교체·펑크·위치교환)
  OIL          // 엔진오일 (교환·보충)
  BRAKE        // 브레이크 (패드·디스크·점검)
  MAINTENANCE  // 경정비 (에어컨·배터리·기타)
  CONSULT      // 종합상담 (뭘 해야 할지 모를 때)
}

// 서비스 문의 상태
enum ServiceInquiryStatus {
  PENDING    // 접수됨 (텔레그램 알림 발송 완료)
  SHARED     // 운영자가 단톡방에 공유함
  CONNECTED  // 정비사-고객 연결됨
  COMPLETED  // 정비 완료
}

// ========================================
// 🔔 서비스 문의 모델
// ========================================
model ServiceInquiry {
  id            Int                    @id @default(autoincrement())

  // 사용자 연결
  userId        Int?
  user          User?                  @relation(fields: [userId], references: [id])
  name          String?                // 비로그인 고객 이름

  // 지역 정보
  regionSido    String                 // 시/도 (예: "경기도")
  regionSigungu String                 // 시/군/구 (예: "수원시")
  regionDong    String?                // 동/읍/면 (예: "영통동", 선택사항)

  // 고객 전화번호 (접수 시점 기록)
  phone         String?

  // 서비스 정보
  serviceType   ServiceType            // 정비 항목
  description   String?   @db.Text    // 추가 설명 (선택)

  // 차량 정보 (선택)
  vehicleNumber String?                // 차량번호 (예: 12가3456)
  vehicleModel  String?                // 차종 (예: 현대 아반떼)

  // 상태
  status        ServiceInquiryStatus   @default(PENDING)

  // 카카오 오픈채팅 URL
  kakaoOpenChatUrl  String?  // 운영자가 지정한 카카오 오픈채팅 링크

  // 텔레그램 알림 발송 여부
  telegramSent    Boolean   @default(false)
  telegramSentAt  DateTime?

  // 공유 링크 만료 시간 (공유 시 자동 기록, 24시간 후 전화번호 블러)
  sharedAt        DateTime?

  // 공유 링크 클릭 수 (링크가 몇 번 열렸는지)
  shareClickCount Int @default(0)

  // 추적 링크 코드
  trackingCode    String?
  trackingLink    TrackingLink?          @relation(fields: [trackingCode], references: [code])

  // 선택된 정비소 (선택사항)
  mechanicId    Int?
  mechanic      Mechanic?              @relation(fields: [mechanicId], references: [id])

  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  @@index([userId])
  @@index([regionSido, regionSigungu])
  @@index([regionSido, regionSigungu, regionDong])
  @@index([serviceType])
  @@index([status])
  @@index([createdAt])
  @@index([trackingCode])
  @@index([mechanicId])
}

// 타이어 문의 모델
model TireInquiry {
  id            Int                @id @default(autoincrement())

  // 지역 정보
  region        String             // 시/도 (예: "서울특별시")
  subRegion     String?            // 시/군/구 (예: "강남구")

  // 타이어 정보
  tireSize      String             // 타이어 사이즈 (예: "225/45R17")
  serviceType   TireServiceType    @default(REPLACEMENT)

  // 차량 정보 (선택)
  carModel      String?            // 차종

  // 사진
  images        Json?              // ["url1", "url2"] - 타이어 옆면 사진

  // 추가 설명
  description   String?            @db.Text

  // 상태
  status        TireInquiryStatus  @default(PENDING)

  // 관리자 메모
  adminNote     String?            @db.Text

  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([region])
  @@index([status])
  @@index([createdAt])
}

// ========================================
// 커뮤니티 Q&A 모델
// ========================================

enum PostCategory {
  REPAIR      // 정비 일반
  TIRE        // 타이어
  ENGINE_OIL  // 엔진오일
  BRAKE       // 브레이크
  GENERAL     // 자유게시판
}

model Post {
  id           Int          @id @default(autoincrement())
  title        String       @db.VarChar(200)
  content      String       @db.Text
  category     PostCategory @default(GENERAL)
  userId       Int?
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  viewCount    Int          @default(0)
  likeCount    Int          @default(0)
  commentCount Int          @default(0)
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  comments     Comment[]
  likes        PostLike[]

  @@index([category, createdAt])
  @@index([userId])
  @@index([isActive, createdAt])
}

model Comment {
  id         Int        @id @default(autoincrement())
  postId     Int
  post       Post       @relation(fields: [postId], references: [id], onDelete: Cascade)
  content    String     @db.Text
  userId     Int?
  user       User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  parentId   Int?
  parent     Comment?   @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies    Comment[]  @relation("CommentReplies")
  isActive   Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([postId, createdAt])
  @@index([userId])
  @@index([parentId])
}

model PostLike {
  id         Int        @id @default(autoincrement())
  postId     Int
  post       Post       @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId     Int?
  user       User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt  DateTime   @default(now())

  @@unique([postId, userId])
  @@index([postId])
}

// ========================================
// 💰 인센티브 현황판 모델
// ========================================

// 인센티브 전용 사용자
model IncentiveUser {
  id            String   @id @default(uuid())
  loginId       String   @unique
  password      String   // bcrypt
  name          String
  role          String   @default("viewer") // "admin", "manager", "director", "viewer"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  editLogs  IncentiveEditLog[]
  uploads   IncentiveUpload[]
}

// 극동 엑셀 업로드 이력
model IncentiveUpload {
  id          String   @id @default(uuid())
  uploaderId  String
  uploader    IncentiveUser @relation(fields: [uploaderId], references: [id])
  month       String          // "26년 3월"
  uploadDate  DateTime        // 업로드 날짜 (주간 집계용)
  fileName    String
  status      String   @default("pending") // "pending", "approved", "rejected"
  approvedAt  DateTime?
  rawData     Json?           // 파싱된 원본 데이터
  createdAt   DateTime @default(now())

  @@index([month])
  @@index([status])
}

// 팀 인센티브 데이터
model IncentiveData {
  id         String   @id @default(uuid())
  month      String          // "26년 3월"
  uploadDate DateTime        // 이 데이터가 입력된 날짜 (주간 추이용)
  itemKey    String          // "brake_oil" 등
  sales      Float    @default(0)
  qty        Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([month, uploadDate, itemKey])
  @@index([month])
}

// 품목별 최소수량 목표
model IncentiveTarget {
  id      String @id @default(uuid())
  month   String
  itemKey String
  minQty  Int    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([month, itemKey])
}

// 김권중(매니저) 인센티브 데이터
model ManagerIncentiveData {
  id             String   @id @default(uuid())
  month          String
  uploadDate     DateTime
  tireSales      Float    @default(0)
  alignmentSales Float    @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([month, uploadDate])
}

// 이정석(부장) 인센티브 데이터
model DirectorIncentiveData {
  id            String   @id @default(uuid())
  month         String
  uploadDate    DateTime
  totalRevenue  Float    @default(0)
  wiperSales    Float    @default(0)
  batterySales  Float    @default(0)
  acFilterSales Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([month, uploadDate])
}

// 월별 매출 목표 (매출 성장률 인센티브 대시보드)
model MonthlySalesTarget {
  id         String   @id @default(cuid())
  year       Int
  month      Int
  lyTotal    BigInt   // 작년 동월 총매출
  lyDays     Int      // 작년 영업일수
  tysSales   BigInt   // 올해 누적매출
  tyElapsed  Int      // 경과 영업일
  tyRemain   Int      // 남은 영업일
  customPct1 Float    @default(10)
  customPct2 Float    @default(15)
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  @@unique([year, month])
}

// 김권중(매니저) 매출 목표 — 타이어+얼라이먼트
model ManagerMonthlySalesTarget {
  id         String   @id @default(cuid())
  year       Int
  month      Int
  lyTotal    BigInt   // 작년 동월 타이어+얼라이먼트 총매출
  lyDays     Int      // 작년 영업일수
  tysSales   BigInt   // 올해 누적매출
  tyElapsed  Int      // 경과 영업일
  tyRemain   Int      // 남은 영업일
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  @@unique([year, month], name: "year_month")
}

// 상품코드 매핑
model ProductCodeMapping {
  id          String  @id @default(uuid())
  code        String  @unique
  isPrefix    Boolean @default(false)
  category    String            // "tire", "brake_oil", "lining" 등
  label       String            // 표시명
  isIncentive Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 인센티브 설정
model IncentiveConfig {
  id    String @id @default(uuid())
  key   String @unique
  value Float
  label String
  updatedAt DateTime @updatedAt
}

// 수정 이력
model IncentiveEditLog {
  id        String   @id @default(uuid())
  userId    String
  user      IncentiveUser @relation(fields: [userId], references: [id])
  action    String          // "upload", "approve", "edit_mapping" 등
  detail    String   @db.Text
  editedAt  DateTime @default(now())

  @@index([userId])
  @@index([editedAt])
}

// 현금흐름 데이터
model CashFlow {
  id          String   @id @default(uuid())
  year        Int
  month       Int
  cash        BigInt   @default(0)   // 31일 기준 현금
  investment  BigInt   @default(0)   // 투자자산(증권)
  inventory   BigInt   @default(0)   // 타이어 재고자산
  openingCash BigInt?                // 월초 금고 시재 (이월시재)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([year, month])
}

// ========================================
// 🔧 극동(PsimCarS) 데이터 모델
// A/B 시소 슬롯 시스템: 모든 GD 테이블에 slot 컬럼
// 활성 슬롯(A or B)만 서비스, 비활성 슬롯에 새 데이터 기록 후 전환
// ========================================

// 슬롯 설정 (A/B 시소 제어)
model GdSlotConfig {
  id            Int       @id @default(1)
  activeSlot    String    @default("A")    // "A" | "B" — 현재 서비스 중인 슬롯
  lastSyncAt    DateTime?                  // 마지막 동기화 시각
  lastSyncSlot  String?                    // 마지막으로 데이터 쓴 슬롯
  switchCount   Int       @default(0)      // 전환 횟수 (모니터링)
  updatedAt     DateTime  @updatedAt
}

// 거래처 (극동 CUSTOMS 테이블)
model GdCustomer {
  id            Int       @id @default(autoincrement())
  code          String                     // 극동 거래처 코드
  slot          String    @default("A")    // A/B 시소 슬롯
  name          String                     // 업체명
  ceo           String?                    // 대표자
  phone         String?                    // 전화번호
  fax           String?                    // 팩스
  address       String?                    // 주소
  bizNumber     String?                    // 사업자번호
  bizType       String?                    // 업태
  bizCategory   String?                    // 종목
  memo          String?   @db.Text         // 메모
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sales         GdSaleDetail[]

  @@unique([code, slot])
  @@index([slot])
  @@index([name])
  @@index([bizNumber])
  @@index([phone])
}

// 차량/고객 (극동 ASCUST 테이블)
model GdVehicle {
  id            Int       @id @default(autoincrement())
  code          String                     // 극동 차량 코드
  slot          String    @default("A")    // A/B 시소 슬롯
  plateNumber   String?                    // 차량번호 (IDNO)
  ownerName     String?                    // 고객명/차량명
  rep           String?                    // 담당자
  phone         String?                    // 연락처
  address       String?                    // 주소
  carModel      String?                    // 차종 (CJONG)
  carModel2     String?                    // 차종2 (BJONG)
  color         String?                    // 색상
  displacement  String?                    // 배기량
  modelYear     String?                    // 연식 (YDAY)
  purchaseDate  String?                    // 구매일 (CDAY)
  memo          String?   @db.Text         // 메모
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  repairs       GdRepair[]

  @@unique([code, slot])
  @@index([slot])
  @@index([plateNumber])
  @@index([ownerName])
  @@index([phone])
  @@index([carModel])
}

// 상품 (극동 GOODS 테이블)
model GdProduct {
  id            Int       @id @default(autoincrement())
  code          String                     // 극동 상품 코드
  slot          String    @default("A")    // A/B 시소 슬롯
  name          String                     // 상품명
  altName       String?                    // 별칭 (XNAME)
  unit          String?                    // 단위 (EA, 리터 등)
  costPrice     Float     @default(0)      // 원가 (COST_B)
  sellPrice1    Float     @default(0)      // 판매가 1단계
  sellPrice2    Float     @default(0)      // 판매가 2단계
  sellPrice3    Float     @default(0)      // 판매가 3단계
  sellPrice4    Float     @default(0)      // 판매가 4단계
  sellPrice5    Float     @default(0)      // 판매가 5단계
  fixedPrice    Float     @default(0)      // 정가 (FIXP)
  stock         Float     @default(0)      // 재고 (JAEGO)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  saleDetails   GdSaleDetail[]

  @@unique([code, slot])
  @@index([slot])
  @@index([name])
  @@index([code])
}

// 전표 상세 (극동 DATAS 테이블 — 거래처 판매 기록)
model GdSaleDetail {
  id            Int       @id @default(autoincrement())
  fno           String                     // 전표번호
  slot          String    @default("A")    // A/B 시소 슬롯
  saleDate      String?                    // 거래일자 (YYYY-MM-DD) — 파싱 실패 시 null
  saleType      String?                    // 입출고 구분 (1=입고, 2=판매, 3=반품)
  customerCode  String                     // 거래처 코드
  customer      GdCustomer @relation(fields: [customerCode, slot], references: [code, slot])
  productCode   String                     // 상품 코드
  product       GdProduct  @relation(fields: [productCode, slot], references: [code, slot])
  productName   String?                    // 품목명
  qty           Float      @default(0)     // 수량
  unitPrice     Float      @default(0)     // 단가
  amount        Float      @default(0)     // 금액
  createdAt     DateTime   @default(now())

  @@index([slot, saleDate])
  @@index([slot, customerCode])
  @@index([slot, productCode])
  @@index([customerCode, saleDate])
  @@index([fno])
}

// 정비 이력 (극동 ASDATA 테이블 — 차량 정비 기록)
model GdRepair {
  id            Int        @id @default(autoincrement())
  fno           String?                    // 작업번호
  slot          String     @default("A")   // A/B 시소 슬롯
  vehicleCode   String?                    // 거래처/차량 코드 (DATAS.CUST)
  vehicle       GdVehicle? @relation(fields: [vehicleCode, slot], references: [code, slot])
  customerCode  String?                    // 거래처 코드 (DATAS 원본 CUST)
  repairDate    String?                    // 날짜 (YYYY-MM-DD)
  productCode   String?                    // 상품 코드
  productName   String?                    // 품목명
  unit          String?                    // 단위
  qty           Float      @default(0)     // 수량
  unitPrice     Float      @default(0)     // 단가
  amount        Float      @default(0)     // 금액
  mileage       Float?                     // 주행거리 (km)
  memo          String?                    // 비고
  createdAt     DateTime   @default(now())

  @@index([slot, vehicleCode])
  @@index([slot, customerCode])
  @@index([slot, repairDate])
  @@index([vehicleCode, repairDate])
}

// 고객 리마인더 (자동 알림 시스템)
// 슬롯과 무관 — 차량코드로 검색 시 활성 슬롯의 GdVehicle과 조인
model CustomerReminder {
  id            Int       @id @default(autoincrement())
  vehicleCode   String                     // 차량 코드 (GdVehicle.code, 슬롯 무관)
  reminderType  String                     // "oil_change" | "tire_rotation" | "no_visit_3m" | "no_visit_6m" | "inspection" | "custom"
  dueDate       DateTime                   // 알림 예정일
  status        String    @default("pending") // "pending" | "sent" | "completed" | "dismissed"
  message       String?   @db.Text         // 발송 메시지 내용
  sentAt        DateTime?                  // 발송일시
  completedAt   DateTime?                  // 완료(방문)일시
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([vehicleCode])
  @@index([dueDate])
  @@index([status])
}

// 동기화 이력 (극동 데이터 임포트 기록)
model GdSyncLog {
  id            Int       @id @default(autoincrement())
  syncType      String                     // "full" | "incremental" | "close"
  tableName     String                     // 동기화한 테이블명 ("all" | 개별 테이블)
  slot          String?                    // 임포트된 슬롯 ("A" | "B")
  rowCount      Int       @default(0)      // 처리 건수
  status        String    @default("running") // "running" | "completed" | "failed"
  sourceHash    String?                    // GDB 파일 MD5 (중복 방지)
  errorMessage  String?   @db.Text
  startedAt     DateTime  @default(now())
  completedAt   DateTime?

  @@index([status, completedAt])
  @@index([sourceHash])
}

// ========================================
// 🎬 유튜브 서포터 (YouTube Supporter)
// ========================================

// 프로젝트 상태
enum YtProjectStatus {
  IN_PROGRESS   // 진행 중
  COMPLETED     // 완료
}

// 영상 프로젝트 (서랍 1)
model YtProject {
  id              String           @id @default(uuid())
  title           String           // 주제명 (예: "브레이크 패드")
  shootingDate    DateTime?        // 촬영 예정일
  status          YtProjectStatus  @default(IN_PROGRESS)
  sortOrder       Int              @default(0) // 정렬 순서
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  // 관계
  referenceVideos YtReferenceVideo[]
  productionData  YtProductionData[]

  @@index([status])
  @@index([createdAt])
}

// 레퍼런스 영상 (서랍 2)
model YtReferenceVideo {
  id                  String    @id @default(uuid())
  projectId           String
  project             YtProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  youtubeUrl          String    // 영상 URL
  videoId             String    // YouTube 영상 ID
  channelName         String    // 채널명
  channelId           String?   // 채널 ID
  title               String    // 영상 제목
  subscriberCount     Int       @default(0) // 구독자 수
  viewCount           Int       @default(0) // 조회수
  viewSubRatio        Float     @default(0) // 조회수/구독자 비율 (핵심 KPI)
  language            String    @default("ko") // "ko" | "en"
  thumbnailUrl        String?   // 썸네일 URL
  transcript          String?   @db.Text // 전체 자막
  introAnalysis       String?   @db.Text // 첫 30초 분석
  contentAnalysis     String?   @db.Text // 본문 분석
  whatToSay           String?   @db.Text // 메시지 본질
  structureAnalysis   String?   @db.Text // 3막 9단계 구조 분석
  lessonsLearned      String?   @db.Text // 배울 점
  createdAt           DateTime  @default(now())

  @@index([projectId])
  @@index([viewSubRatio])
}

// 제작 내용 (서랍 3)
model YtProductionData {
  id                    String    @id @default(uuid())
  projectId             String
  project               YtProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  version               Int       @default(1) // 버전 1 또는 2
  coreValue             String?   @db.Text // 코어벨류
  introSources          Json?     // 인트로 소재 (30초 대본 + 댓글 분석)
  introDrafts           Json?     // 인트로 문구 후보들 (배열)
  scriptDraft           String?   @db.Text // 대본 초안
  thumbnailStrategies   Json?     // 썸네일 문구 전략 3개
  titles                Json?     // 제목 후보 3개 (배열)
  hashtags              Json?     // 해시태그 (배열)
  description           String?   @db.Text // 설명란
  timeline              String?   @db.Text // 타임라인 (영상 완성 후)
  opusReview            String?   @db.Text // Opus 검수 결과
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([projectId, version])
  @@index([projectId])
}

// 스킬 노트 (서랍 4)
model YtSkillNote {
  id          String   @id @default(uuid())
  category    String   // "script" | "thumbnail" | "intro" | "shortform" | "other"
  title       String   // 스킬 제목
  content     String   @db.Text // 스킬 내용
  source      String?  // 출처 (어떤 영상/뉴스레터에서 배웠는지)
  tags        String[] // 검색용 태그
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([createdAt])
}

// 등록 채널 (주제 찾기용)
model YtChannel {
  id              String    @id @default(uuid())
  channelId       String    @unique
  channelName     String
  channelUrl      String
  thumbnailUrl    String?
  subscriberCount Int       @default(0)
  videoCount      Int       @default(0)
  category        String    @default("정비")
  memo            String?
  avgViewCount    Int       @default(0)
  lastSyncedAt    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([category])
}

// 카테고리 관리
model YtCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

// 검색 캐시 (YouTube API 호출 절약)
model YtSearchCache {
  id            String   @id @default(uuid())
  cacheKey      String   @unique       // keyword+language+duration 해시
  keyword       String
  language      String   @default("ko")
  videoDuration String?                // short | medium | long
  results       Json                   // 검색 결과 JSON
  expiresAt     DateTime               // 캐시 만료 시각
  createdAt     DateTime @default(now())

  @@index([expiresAt])
}
