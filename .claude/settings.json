{
  "permissions": {
    "allow": [
      "Skill",
      "Read",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Task"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"작업 완료!\" with title \"Claude Code\" sound name \"Glass\"' 2>/dev/null; echo '[Stop] tasks/todo.md 업데이트 확인'",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}
